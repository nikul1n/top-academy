strickmode компонент который проверяет что всё апроисходит строго
он покажет всякие интересные циклические зависимости

зависимости рекомендуется устанавливать когда есть последствия 

function Counter() {
  const [count, setCount] = useState(0)

  const increment = () => setCount(count + 1)

  return (

        <button
          type="button"
          className="counter"
          onClick={() => setCount((count) => count + 1)}
        >
          Count is {count}
        </button>
  )

}

export default Counter